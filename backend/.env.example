# MongoDB Configuration
# URI for MongoDB connection
# Format: mongodb://[username:password@]host[:port]/database
# Example: mongodb://127.0.0.1:27017/fetms
MONGO_URI=mongodb://127.0.0.1:27017/fetms

# Server Configuration
# Port number for the Express server
# Default: 5000
PORT=5000

# Node Environment
# Options: development, production, test
# Affects logging, error handling, and performance optimizations
NODE_ENV=development

# CORS
# Allowed origin for the frontend (used to restrict CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Gmail SMTP for Email Notifications
# Used by EmailService to send bulk and alert emails via Gmail SMTP.
#
# GMAIL_USER: your Gmail address (e.g. yourname@gmail.com)
# GMAIL_APP_PASSWORD: a 16-character App Password (NOT your Gmail account password).
#   Generate one at: https://myaccount.google.com/apppasswords
#   (Requires 2-Step Verification to be enabled on your Google account)
# EMAIL_FROM_NAME: Display name shown in the "From:" header of sent emails
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=FETMS System

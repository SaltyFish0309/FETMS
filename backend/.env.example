# MongoDB Configuration
# URI for MongoDB connection
# Format: mongodb://[username:password@]host[:port]/database
# Example: mongodb://127.0.0.1:27017/fetms
MONGO_URI=mongodb://127.0.0.1:27017/fetms

# Server Configuration
# Port number for the Express server
# Default: 5000
PORT=5000

# Node Environment
# Options: development, production, test
# Affects logging, error handling, and performance optimizations
NODE_ENV=development

# CORS
# Allowed origin for the frontend (used to restrict CORS)
FRONTEND_ORIGIN=http://localhost:5173

# OAuth 2.0 Email Configuration
# Used to encrypt OAuth tokens stored in MongoDB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=your-64-char-hex-string-here

# OAuth Redirect URI (must match Google Cloud Console registration)
# Default: http://localhost:5000/api/email-config/callback
# OAUTH_REDIRECT_URI=http://localhost:5000/api/email-config/callback

# Removed: GMAIL_USER, GMAIL_APP_PASSWORD, EMAIL_FROM_NAME
# These are now configured through Settings UI at /settings/email-config
